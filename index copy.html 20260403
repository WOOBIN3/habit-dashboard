      input.type = "file";
      input.accept = ".json,application/json";

      input.onchange = async (e) => {
        const file = e.target.files?.[0];
        if (!file) return;

        if (!navigator.onLine) {
        showToast("오프라인 상태에서는 백업 복원을 완료할 수 없어.", "error");
        return;
}

        try {
