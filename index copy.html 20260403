async function handleHabitListClick(event) {
  const rowEl = event.target.closest("#habitTableBody tr");
  if (!rowEl) return;

  const rowId = rowEl.dataset.habitId;
  if (!rowId) return;

  const habits = getHabits();
  const rowIndex = habits.findIndex(
    (habit) => String(habit.id) === String(rowId)
  );
  if (rowIndex === -1) return;

  const actionButton = event.target.closest("[data-action]");

  if (actionButton) {
    event.preventDefault();
    event.stopPropagation();

    const action = actionButton.dataset.action;
    const actionIndex = Number(actionButton.dataset.index);
    const targetIndex = Number.isNaN(actionIndex) ? rowIndex : actionIndex;

    if (action === "edit") {
      window.startEditHabit(targetIndex);
      return;
    }

    if (action === "delete") {
      deleteHabit(targetIndex);
      return;
    }

    if (action === "toggle-today") {
      await toggleTodayFromCard(rowId);
      return;
    }

    if (action === "move-up") {
      moveHabitUp(targetIndex);
      return;
    }

    if (action === "move-down") {
      moveHabitDown(targetIndex);
      return;
    }

    if (action === "save-edit") {
      const input = rowEl.querySelector(".edit-input");
      const nextValue = input ? input.value : editingHabitValue;
      saveHabitEdit(targetIndex, nextValue);
      return;
    }

    if (action === "cancel-edit") {
      window.cancelHabitEdit();
      return;
    }

    return;
  }

  const dayBox = event.target.closest(".day-box");
  if (dayBox) {
    event.preventDefault();
    event.stopPropagation();

    const habitId = dayBox.dataset.habitId;
    const dayIndex = Number(dayBox.dataset.dayIndex);

    if (!habitId || Number.isNaN(dayIndex)) return;

    const checks = ensureHabitData(habitId);
    const nextChecked = !checks[dayIndex];
    checks[dayIndex] = nextChecked;

    await saveCheckToSupabase(habitId, dayIndex, nextChecked);
    await saveState();

    renderHabitList();
    renderSelectedHabitPanel();

    return;
  }

  if (shouldBlockHabitRowAction(event)) return;

  selectHabit(rowId);
  updateTopDashboardStats();
}

