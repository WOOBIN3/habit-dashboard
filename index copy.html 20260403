async function moveHabitByDrag(fromIndex, toIndex) {
  const habits = getHabits();

  if (fromIndex === null || toIndex === null || fromIndex === toIndex) return;
  if (fromIndex < 0 || toIndex < 0) return;
  if (fromIndex >= habits.length || toIndex >= habits.length) return;

  const moved = habits[fromIndex];
  habits.splice(fromIndex, 1);
  habits.splice(toIndex, 0, moved);
  habits.forEach((habit, index) => {
    habit.position = index;
  });

  await saveState();
  renderAll();
}

    function moveHabitUp(index) {
      if (index === 0) return;

      const habits = getHabits();
      [habits[index - 1], habits[index]] = [habits[index], habits[index - 1]];
      habits.forEach((habit, i) => habit.position = i);

      saveState();
      renderAll();
    }

function clearTouchDragState() {
  document.querySelectorAll("#checkTable tbody tr").forEach((el) => {
    el.classList.remove("touch-dragging");
    el.classList.remove("drag-over");
    el.style.transform = "";
  });

  const list = document.querySelector(".habit-list");
  if (list) {
    list.classList.remove("drag-active");
  }

  if (touchHoldTimer) {
    clearTimeout(touchHoldTimer);
    touchHoldTimer = null;
  }

  document.removeEventListener("touchmove", handleTouchMove, { passive: false });
  document.removeEventListener("touchend", handleTouchEndBound);
  document.removeEventListener("touchcancel", clearTouchDragState);

  touchDragIndex = null;
  touchCurrentTargetIndex = null;
  touchStartY = 0;
  isTouchDragging = false;
  touchMoved = false;
  handleTouchEndBound = null;
}

function handleTouchMove(e) {
  if (!e.touches || !e.touches.length) return;

  // 🔥 검색 중이면 드래그 막기
  if (habitSearchKeyword && habitSearchKeyword.trim() !== "") {
    return;
  }

  const touch = e.touches[0];
  const currentY = touch.clientY;
  const offsetY = currentY - touchStartY;

  if (Math.abs(currentY - touchStartY) > 18) {
    touchMoved = true;
  }

  if (!isTouchDragging) return;

  e.preventDefault();

  const rows = [...document.querySelectorAll(".habit-row")];
  const draggingRow = rows[touchDragIndex];

  if (draggingRow) {
    draggingRow.style.transform = `translateY(${offsetY}px) scale(1.02)`;
  }

  rows.forEach((el) => {
    el.classList.remove("drag-over");
    el.classList.remove("drop-target-pulse");
  });

  const target = document.elementFromPoint(touch.clientX, touch.clientY);
  if (!target) return;

  const targetRow = target.closest(".habit-row");
  if (!targetRow) return;

  const targetIndex = rows.indexOf(targetRow);

  if (targetIndex === -1 || targetIndex === touchDragIndex) return;

  targetRow.classList.add("drag-over");
  targetRow.classList.add("drop-target-pulse");
  touchCurrentTargetIndex = targetIndex;
}

function handleTouchEnd(e, row, habitId) {
  if (touchHoldTimer) {
    clearTimeout(touchHoldTimer);
    touchHoldTimer = null;
  }

  const target = e.target;

  if (
    target.closest("button") ||
    target.closest("input") ||
    target.closest(".edit-input")
  ) {
    clearTouchDragState();
    return;
  }

  if (isTouchDragging) {
    if (
      touchDragIndex !== null &&
      touchCurrentTargetIndex !== null &&
      touchDragIndex !== touchCurrentTargetIndex
    ) {
      moveHabitByDrag(touchDragIndex, touchCurrentTargetIndex);
    }

    suppressNextClick = true;
    suppressClickUntil = Date.now() + 250;

    clearTouchDragState();
    return;
  }

  if (!touchMoved) {
    suppressNextClick = true;
    selectHabit(habitId);
  }

  clearTouchDragState();
}

    function moveHabitDown(index) {
      const habits = getHabits();
      if (index === habits.length - 1) return;

      [habits[index], habits[index + 1]] = [habits[index + 1], habits[index]];
      habits.forEach((habit, i) => habit.position = i);

      saveState();
      renderAll();
    }

    function getTodayStats() {
      const habits = getHabits();
      const total = habits.length;
      let done = 0;

      habits.forEach((habit) => {
        const checks = ensureHabitData(habit.id);
        if (checks[currentDay - 1]) done++;
      });

      const remain = total - done;
      const rate = total === 0 ? 0 : Math.round((done / total) * 100);

      return { total, done, remain, rate };
    }

    function getMonthStats() {
      const habits = getHabits();
      const totalPossible = habits.length * daysInMonth;
      let done = 0;

      habits.forEach((habit) => {
        const checks = ensureHabitData(habit.id);
        done += checks.filter(Boolean).length;
      });

      const rate = totalPossible === 0 ? 0 : Math.round((done / totalPossible) * 100);

      return { totalPossible, done, rate };
    }

    function getDailySuccessCounts() {
      const habits = getHabits();
      const counts = [];

      for (let day = 0; day < daysInMonth; day++) {
        let dayDone = 0;
        habits.forEach((habit) => {
          const checks = ensureHabitData(habit.id);
          if (checks[day]) dayDone++;
        });
        counts.push(dayDone);
      }

      return counts;
    }

    function getHabitPercentages() {
      return getHabits().map((habit) => {
        const checks = ensureHabitData(habit.id);
        const done = checks.filter(Boolean).length;
        return Math.round((done / daysInMonth) * 100);
      });
    }

    function getBestStreak(checks) {
  let best = 0;
  let current = 0;

  for (let i = 0; i < checks.length; i++) {
    if (checks[i]) {
      current++;
      if (current > best) best = current;
    } else {
      current = 0;
    }
  }

  return best;
}

    function getStreakBadge(streak) {
  if (streak === 0) return "연속 없음";
  if (streak >= 14) return "🔥 " + streak + "일 연속 🏆";
  if (streak >= 7) return "🔥 " + streak + "일 연속 👑";
  return "🔥 " + streak + "일 연속";
}

    function getStreakBadgeClass(streak) {
  if (streak === 0) return "streak-badge streak-warning";
  if (streak >= 14) return "streak-badge streak-great";
  if (streak >= 7) return "streak-badge streak-good";
  return "streak-badge";
}

function getStreak(checks) {
  let streak = 0;
  for (let i = currentDay - 1; i >= 0; i--) {
    if (checks[i]) streak++;
    else break;
  }
  return streak;
}

    function getHabitCardData(habit) {
      const checks = ensureHabitData(habit.id);
      const done = checks.filter(Boolean).length;
      const todayDone = checks[currentDay - 1];
      const streak = getStreak(checks);
      const bestStreak = getBestStreak(checks);
      const percent = Math.round((done / daysInMonth) * 100);

   return {
  done,
  todayDone,
  streak,
  bestStreak,
  percent,
  streakLabel: getStreakBadge(streak),
  streakClass: getStreakBadgeClass(streak),

  bestStreakClass:
    bestStreak >= 14
      ? "best-streak-badge best-streak-great"
      : bestStreak >= 7
      ? "best-streak-badge best-streak-good"
      : "best-streak-badge",
};

    }

    function escapeHtml(text) {
      if (!text) return "";
      return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

function getHabitRowElementById(habitId) {
  return document.querySelector(`#checkTable tbody tr[data-habit-id="${String(habitId)}"]`);
}

function renderHabitRowById(habitId) {
  const rowEl = getHabitRowElementById(habitId);
  if (!rowEl) {
    return;
  }

  const habits = getHabits();
  const index = habits.findIndex((habit) => String(habit.id) === String(habitId));
  const habit = habits[index];

  if (!habit || index === -1) {
    return;
  }

  const keyword = String(habitSearchKeyword || "").trim().toLowerCase();
  const matched =
    !keyword || String(habit.name || "").toLowerCase().includes(keyword);

  if (!matched) {
    return;
  }

  const checks = ensureHabitData(habit.id);
  const done = checks.filter(Boolean).length;

  rowEl.innerHTML = `
    <td class="habit-name-cell">
      <div class="habit-name-main">${escapeHtml(habit.name)}</div>
      <div class="habit-name-sub">${done}/${daysInMonth}</div>
    </td>
    ${Array.from({ length: daysInMonth }, (_, dayIndex) => {
      const checked = checks[dayIndex];
      const isToday = dayIndex + 1 === currentDay;

      return `
        <td class="habit-check-cell ${isToday ? "today-col" : ""}">
          <div
            class="day-box ${checked ? "checked" : ""}"
            data-habit-id="${habit.id}"
            data-day-index="${dayIndex}"
          ></div>
        </td>
      `;
    }).join("")}
  `;

  rowEl.dataset.habitId = habit.id;
}

