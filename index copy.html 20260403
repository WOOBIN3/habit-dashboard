    function getMonthChecks() {
      if (!appState.monthData[monthKey]) {
        appState.monthData[monthKey] = {};
      }
      return appState.monthData[monthKey];
    }

    function ensureHabitData(habitId) {
      const monthChecks = getMonthChecks();

      if (!monthChecks[habitId]) {
        monthChecks[habitId] = Array(daysInMonth).fill(false);
      }

      if (monthChecks[habitId].length !== daysInMonth) {
        const newArr = Array(daysInMonth).fill(false);
        for (let i = 0; i < Math.min(monthChecks[habitId].length, daysInMonth); i++) {
          newArr[i] = monthChecks[habitId][i];
        }
        monthChecks[habitId] = newArr;
      }

      return monthChecks[habitId];
    }

    function syncHabitData() {
      const habits = getHabits();
      const monthChecks = getMonthChecks();

      habits.forEach((habit) => ensureHabitData(habit.id));

      Object.keys(monthChecks).forEach((habitId) => {
        if (!habits.some(habit => habit.id === habitId)) {
          delete monthChecks[habitId];
        }
      });
    }

function addPendingCheck(habitId, dayIndex, checked) {
  const existingIndex = appState.pendingCheckQueue.findIndex((item) =>
    item.habitId === habitId && item.dayIndex === dayIndex
  );

  const newItem = { habitId, dayIndex, checked };

  if (existingIndex >= 0) {
    appState.pendingCheckQueue[existingIndex] = newItem;
  } else {
    appState.pendingCheckQueue.push(newItem);
  }

  saveLocalState();
  updateNetworkStatus();
}

async function flushPendingChecks() {
  if (!navigator.onLine) return;
  if (!currentUser) return;
  if (!appState.pendingCheckQueue.length) return;
  if (appState.isSyncing) return;

  appState.isSyncing = true;

  try {
    const queueCopy = [...appState.pendingCheckQueue];
    const failedQueue = [];

    showToast("동기화 중.", "info");
    await new Promise(resolve => setTimeout(resolve, 500));

    for (const item of queueCopy) {
      try {
        await saveCheckToSupabase(item.habitId, item.dayIndex, item.checked);
      } catch (error) {
        failedQueue.push(item);
        console.error("개별 체크 동기화 실패:", item, error);
      }
    }

    appState.pendingCheckQueue = failedQueue;
    saveLocalState();
    updateNetworkStatus();

    if (failedQueue.length === 0) {
      showToast("오프라인 체크가 동기화됐어.", "success");
    } else {
      showToast(`일부 체크(${failedQueue.length}개) 동기화 실패`, "error");

      setTimeout(() => {
        flushPendingChecks();
      }, 3000);
    }
  } finally {
    appState.isSyncing = false;
  }
}

