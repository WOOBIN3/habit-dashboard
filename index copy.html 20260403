async function initApp() {
  const isTempLoggedIn = localStorage.getItem("tempHabitLogin") === "1";

  if (isTempLoggedIn) {
    document.getElementById("authScreen")?.classList.add("hidden");
    document.getElementById("appScreen")?.classList.remove("hidden");

    const savedState =
      localStorage.getItem("habitDashboardDataPWA") ||
      localStorage.getItem(localStorage.getItem("habitDashboardLastUserKey") || "");

    if (savedState && typeof openOfflineFromSavedState === "function") {
      openOfflineFromSavedState(savedState);
      return;
    }

    showAppScreen();
    if (typeof renderAll === "function") renderAll();
    updateNetworkStatus();
    return;
  }

  setHeaderDate();
  updateNetworkStatus();
  setupInstallButton();

  const lastUserKey = localStorage.getItem("habitDashboardLastUserKey");
  const savedState = lastUserKey ? localStorage.getItem(lastUserKey) : null;

  if (!navigator.onLine) {
    const opened = openOfflineFromSavedState(savedState);

    if (!opened) {
      showAuthScreen();
      setAuthMessage("오프라인 상태라 저장된 데이터가 있을 때만 앱을 열 수 있어.", true);
    }

    return;
  }

  try {
    const user = await getCurrentUser();

    if (!user) {
      const opened = openOfflineFromSavedState(savedState);

      if (!opened) {
        currentUser = null;
        resetAppState();
        showAuthScreen();
      }

      return;
    }

    currentUser = user;
    document.getElementById("userEmail").textContent = currentUser.email || "";

    showAppScreen();
    await loadHabitsFromSupabase();
  } catch (error) {
    console.error("initApp 사용자 조회 실패:", error);

    const opened = openOfflineFromSavedState(savedState);

    if (opened) return;

    currentUser = null;
    resetAppState();
    showAuthScreen();
  }
}

