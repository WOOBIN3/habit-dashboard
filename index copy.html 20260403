    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: "rgba(9,18,32,0.96)",
          titleColor: "#f3f1ea",
          bodyColor: "#c9d4ea",
          borderColor: "rgba(125,211,252,0.18)",
          borderWidth: 1
        }
      },
      scales: {
        x: {
          ticks: {
            color: "#8fa4c2",
            maxTicksLimit: 12
          },
          grid: {
            color: "rgba(255,255,255,0.04)"
          }
        },
        y: {
          beginAtZero: true,
          ticks: {
            color: "#8fa4c2",
            precision: 0
          },
          grid: {
            color: "rgba(255,255,255,0.05)"
          }
        }
      }
    }
  });
