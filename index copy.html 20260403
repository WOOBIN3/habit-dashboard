  const now = new Date();
  const currentYear = now.getFullYear();
  const currentMonth = now.getMonth() + 1;
  const daysInMonth = new Date(currentYear, currentMonth, 0).getDate();
  const monthKey = `${currentYear}-${String(currentMonth).padStart(2, "0")}`;

  const labels = Array.from({ length: daysInMonth }, (_, i) => String(i + 1));
  const dailyCounts = Array(daysInMonth).fill(0);

  habits.forEach((habit) => {
    const checks = window.appState?.monthData?.[monthKey]?.[habit.id] || [];
    for (let i = 0; i < daysInMonth; i++) {
      if (checks[i]) dailyCounts[i] += 1;
    }
  });

  if (mainLineChartInstance) {
    mainLineChartInstance.destroy();
  }

  mainLineChartInstance = new Chart(canvas, {
    type: "line",
    data: {
      labels,
      datasets: [
        {
          label: "일별 완료 수",
          data: dailyCounts,
          borderColor: "#8fb4ff",
          backgroundColor: "rgba(143, 180, 255, 0.18)",
          tension: 0.35,
          fill: true,
          pointRadius: 2,
          pointHoverRadius: 4,
          borderWidth: 2
        }
