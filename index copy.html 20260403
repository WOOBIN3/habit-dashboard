async function saveCheckToSupabase(habitId, dayIndex, checked) {
  if (!currentUser) return;

  if (!navigator.onLine) {
    addPendingCheck(habitId, dayIndex, checked);
    return;
  }

  const day = String(dayIndex + 1).padStart(2, "0");
  const month = String(currentMonth).padStart(2, "0");
  const date = `${currentYear}-${month}-${day}`;

  try {
    const { error } = await supabaseClient
      .from("habit_checks")
      .upsert(
        {
          user_id: currentUser.id,
          habit_id: habitId,
          check_date: date,
          checked: checked
        },
        {
          onConflict: "habit_id,check_date"
        }
      );

    if (error) {
      console.error("check 저장 실패:", error.message);
      addPendingCheck(habitId, dayIndex, checked);
    }
  } catch (error) {
    console.error("saveCheckToSupabase 전체 에러:", error);
    addPendingCheck(habitId, dayIndex, checked);
  }
}

async function syncAllChecksToSupabase() {
  if (!currentUser) return;

  const monthData = appState.monthData || {};
  const rows = [];

  Object.keys(monthData).forEach((monthKeyItem) => {
    const checksByHabit = monthData[monthKeyItem] || {};
    const [year, month] = monthKeyItem.split("-");

    Object.keys(checksByHabit).forEach((habitId) => {
      const checks = checksByHabit[habitId] || [];

      checks.forEach((checked, index) => {
        if (!checked) return;

        const day = String(index + 1).padStart(2, "0");

        rows.push({
          user_id: currentUser.id,
          habit_id: habitId,
          check_date: `${year}-${month}-${day}`,
          checked: true
        });
      });
    });
  });

  const { error: deleteError } = await supabaseClient
    .from("habit_checks")
    .delete()
    .eq("user_id", currentUser.id);

  if (deleteError) {
    console.error("기존 체크 삭제 실패:", deleteError.message);
    throw deleteError;
  }

  if (rows.length === 0) return;

  const { error: upsertError } = await supabaseClient
    .from("habit_checks")
    .upsert(rows, {
      onConflict: "habit_id,check_date"
    });

  if (upsertError) {
    console.error("체크 복원 실패:", upsertError.message);
    throw upsertError;
  }
}

