    const checks = ensureHabitData(habit.id);
    for (let i = 0; i < daysInMonth; i++) {
      checks[i] = value;
      promises.push(saveCheckToSupabase(habit.id, i, value));
    }
  });

  Promise.all(promises).then(async () => {
    await saveState();

    const updatedHabits = getHabits();
    updatedHabits.forEach((habit) => renderHabitRowById(habit.id));

    renderSelectedHabitPanel();
    renderAnalysis();
    renderCharts();
    updateKPI();
  });
}

    function exportBackup() {
      try {
        const backupData = {
          exportedAt: new Date().toISOString(),
          appState
        };

        const blob = new Blob(
          [JSON.stringify(backupData, null, 2)],
          { type: "application/json" }
        );

        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        const date = new Date();
        const fileName = `habit-dashboard-backup-${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}.json`;

        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);

        showToast("백업 파일이 저장됐어.", "success");
      } catch (error) {
        console.error("백업 내보내기 실패:", error);
