let topDonutChart = null;

function updateTopDashboardStats() {
  const today = new Date();
  const todayKey = today.toISOString().split('T')[0];

  const habits = JSON.parse(localStorage.getItem('habitDashboardDataPWA')) || [];

  let total = habits.length;
  let complete = 0;

  habits.forEach((habit) => {
    if (habit.records && habit.records[todayKey]) {
      complete++;
    }
  });

  const remaining = Math.max(total - complete, 0);
  const percent = total === 0 ? 0 : Math.round((complete / total) * 100);

  const todayRateEl = document.getElementById('todayRate');
  const completeCountEl = document.getElementById('completeCount');
  const totalCountEl = document.getElementById('totalCount');

  if (todayRateEl) todayRateEl.innerText = percent + '%';
  if (completeCountEl) completeCountEl.innerText = complete;
  if (totalCountEl) totalCountEl.innerText = total;

  const donutCanvas = document.getElementById('donutChart');
  if (!donutCanvas) return;

  if (topDonutChart) {
    topDonutChart.destroy();
  }

  topDonutChart = new Chart(donutCanvas, {
    type: 'doughnut',
    data: {
      labels: ['Complete', 'Remaining'],
      datasets: [
        {
          data: [complete, remaining],
          backgroundColor: ['#5b8cff', 'rgba(255,255,255,0.08)'],
          borderWidth: 0
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '70%',
      plugins: {
        legend: { display: false }
      }
    }
  });
}

updateTopDashboardStats();

window.signIn = async function (event) {
  if (event) event.preventDefault();

  const email = document.getElementById("emailInput")?.value?.trim();
  const password = document.getElementById("passwordInput")?.value;

  if (!email || !password) {
    alert("이메일과 비밀번호 입력해");
    return;
  }

  if (!window.supabase) {
    alert("Supabase 라이브러리가 아직 안 불러와졌어.");
    return;
  }

  if (typeof supabaseClient === "undefined") {
    alert("supabaseClient가 아직 준비되지 않았어.");
    return;
  }

  try {
    const { data, error } = await supabaseClient.auth.signInWithPassword({
      email,
      password
    });

    if (error) {
      alert(error.message);
      return;
    }

    currentUser = data?.user || null;

    if (!currentUser) {
      alert("로그인 정보를 불러오지 못했어.");
      return;
    }

    localStorage.setItem("tempHabitLogin", "1");

    if (typeof loadHabitsFromSupabase === "function") {
      await loadHabitsFromSupabase();
    }

    if (typeof flushPendingChecks === "function") {
      await flushPendingChecks();
    }

    if (typeof showAppScreen === "function") {
      showAppScreen();
    }

    if (typeof renderAll === "function") {
      renderAll();
    }

    const userEmailEl = document.getElementById("userEmail");
    if (userEmailEl) {
      userEmailEl.textContent = currentUser.email || "";
    }
  } catch (error) {
    console.error("로그인 오류:", error);
    alert("로그인 중 오류 발생");
  }
};

