function updateKPI() {
  const habits = getHabits();
  const total = habits.length;

  const today = new Date().getDate() - 1;

  let todayDone = 0;
  let bestStreak = 0;
  let totalDone = 0;
  let totalPossible = 0;

  habits.forEach(habit => {
    if (!habit.days) return;

    if (habit.days[today]) {
      todayDone++;
    }

    habit.days.forEach(d => {
      if (d) totalDone++;
      totalPossible++;
    });

    let current = 0;
    let max = 0;

    habit.days.forEach(d => {
      if (d) {
        current++;
        max = Math.max(max, current);
      } else {
        current = 0;
      }
    });

    bestStreak = Math.max(bestStreak, max);
  });

  const rate = totalPossible === 0
    ? 0
    : Math.round((totalDone / totalPossible) * 100);

  const kpiTotalEl = document.getElementById("kpiTotal");
  const kpiTodayEl = document.getElementById("kpiToday");
  const kpiStreakEl = document.getElementById("kpiStreak");
  const kpiRateEl = document.getElementById("kpiRate");

  if (!kpiTotalEl || !kpiTodayEl || !kpiStreakEl || !kpiRateEl) {
    return;
  }

  kpiTotalEl.textContent = total;
  kpiTodayEl.textContent = todayDone;
  kpiStreakEl.textContent = bestStreak;
  kpiRateEl.textContent = rate + "%";
}

