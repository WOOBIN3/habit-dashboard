function selectHabit(id) {
  const previousHabitId = selectedHabitId;
  const isSameHabit = String(selectedHabitId) === String(id);

  if (isSameHabit) {
    selectedHabitId = null;
    localStorage.removeItem("selectedHabitId");
    renderSelectionUI(previousHabitId);
    return;
  }

  selectedHabitId = id;
  localStorage.setItem("selectedHabitId", String(id));

  renderSelectionUI(previousHabitId);

  requestAnimationFrame(() => {
    const selectedEl = getHabitRowElementById(selectedHabitId);
    if (selectedEl) {
      selectedEl.classList.remove("flash");
      void selectedEl.offsetWidth;
      selectedEl.classList.add("flash");
    }

    const panelEl = document.getElementById("selectedHabitPanel");
    if (panelEl) {
      panelEl.classList.remove("flash");
      void panelEl.offsetWidth;
      panelEl.classList.add("flash");

      if (window.innerWidth <= 1100) {
        panelEl.scrollIntoView({
          behavior: "smooth",
          block: "start"
        });
      }
    }
  });
}

function renderSelectionUI(previousHabitId = null) {
  updateSelectionRowsOnly(previousHabitId, selectedHabitId);
  renderSelectedHabitPanel();
}

