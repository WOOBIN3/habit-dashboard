<script>
window.addHabit = function () {
  const input = document.getElementById("habitInput");
  if (!input) return;

  const name = input.value.trim();
  if (!name) {
    alert("습관 이름을 입력해줘.");
    input.focus();
    return;
  }

  if (!window.appState) {
    window.appState = {
      habits: [],
      monthData: {},
      pendingCheckQueue: [],
      isSyncing: false
    };
  }

  const now = new Date();
  const currentYear = now.getFullYear();
  const currentMonth = now.getMonth() + 1;
  const daysInMonth = new Date(currentYear, currentMonth, 0).getDate();
  const monthKey = `${currentYear}-${String(currentMonth).padStart(2, "0")}`;

  if (!window.appState.monthData[monthKey]) {
    window.appState.monthData[monthKey] = {};
  }

  const newHabit = {
    id: crypto.randomUUID(),
    name,
    position: window.appState.habits.length
  };

  window.appState.habits.push(newHabit);
  window.appState.monthData[monthKey][newHabit.id] = Array(daysInMonth).fill(false);

  input.value = "";

  try {
    localStorage.setItem("habitDashboardDataPWA", JSON.stringify(window.appState));
  } catch (error) {
    console.error("로컬 저장 실패:", error);
  }

  if (typeof renderAll === "function") {
    renderAll();
  } else {
    console.log("addHabit 실행됨, renderAll 없음");
    console.log(window.appState.habits);
  }
};
</script>

<script>
window.renderAll = function () {
  const habits = window.appState?.habits || [];

