.card * {
  position: relative;
  z-index: 1;
}

.card:hover {
  transform: translateY(-4px);
  border-color: rgba(125, 211, 252, 0.22);
  box-shadow:
    0 28px 70px rgba(2, 8, 23, 0.5),
    0 0 0 1px rgba(125, 211, 252, 0.08),
    0 0 30px rgba(56, 189, 248, 0.08);
  background:
    linear-gradient(180deg, rgba(25, 40, 63, 0.98) 0%, rgba(11, 21, 36, 1) 100%);
}

    .card-title {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 10px;
      position: relative;
      z-index: 1;
    }

.section-title {
  font-size: 24px;
  font-weight: 900;
  margin: 0 0 4px;
  color: #f8f3e7;
  position: relative;
  z-index: 1;
  letter-spacing: -0.4px;
  text-shadow: 0 2px 18px rgba(0,0,0,0.25);
}

.section-sub {
  color: #95a2bb;
  font-size: 13px;
  margin-bottom: 12px;
  position: relative;
  z-index: 1;
}

.input-row {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  position: relative;
  z-index: 1;
}

    .habit-input {
      flex: 1;
      height: 50px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #0a0a0a 0%, #11100f 100%);
      color: var(--text);
      padding: 0 16px;
      font-size: 15px;
      outline: none;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

.edit-input {
  width: 100%;
  height: 42px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: linear-gradient(180deg, #0a0a0a 0%, #11100f 100%);
  color: var(--text);
  padding: 0 14px;
  font-size: 16px;
  outline: none;
}

.edit-input:focus {
  border-color: rgba(201,164,76,0.6);
}

    .habit-input::placeholder {
      color: #6f665a;
    }

    .habit-input:focus {
      border-color: rgba(201,164,76,0.6);
      box-shadow: 0 0 0 4px rgba(201,164,76,0.10);
    }

.add-btn {
  min-width: 122px;
  height: 50px;
  border: 1px solid rgba(125, 211, 252, 0.32);
  border-radius: 14px;
  background: linear-gradient(180deg, #7dd3fc 0%, #38bdf8 55%, #0ea5e9 100%);
  color: #04111d;
  font-size: 15px;
  font-weight: 900;
  cursor: pointer;
  box-shadow:
    0 10px 20px rgba(56, 189, 248, 0.22),
    inset 0 1px 0 rgba(255,255,255,0.18);
  transition: transform .15s ease, filter .2s ease;
  position: relative;
  z-index: 1;
}

.search-wrap {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 0;
  margin-bottom: 8px;
}

.search-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

.clear-search-btn {
  min-width: 92px;
  height: 50px;
  padding: 0 14px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.06);
  color: var(--text);
  font-size: 14px;
  font-weight: 800;
  cursor: pointer;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.05),
    0 8px 18px rgba(0,0,0,0.16);
  transition:
    transform .15s ease,
    background .2s ease,
    border-color .2s ease,
    box-shadow .2s ease,
    opacity .2s ease;
}

.clear-search-btn:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(255, 255, 255, 0.16);
}

.clear-search-btn:active:not(:disabled) {
  transform: scale(0.97);
}

.clear-search-btn:disabled {
  opacity: 0.42;
  cursor: default;
  box-shadow: none;
}

.search-status {
  min-height: 18px;
  padding-left: 4px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 600;
}

.habit-highlight {
  display: inline-block;
  padding: 0 4px;
  border-radius: 6px;
  background: rgba(125, 211, 252, 0.24);
  color: #ffffff;
  font-weight: 800;
  box-shadow: 0 0 0 1px rgba(125, 211, 252, 0.14);
}

.add-btn:disabled {
  opacity: 0.65;
  cursor: not-allowed;
}

    .add-btn:active,
    .bulk-btn:active,
    .move-btn:active,
    .delete-btn:active,
    .edit-btn:active,
    .save-btn:active,
    .cancel-btn:active,
    .logout-btn:active {
      transform: scale(0.96);
}

    .bulk-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 16px;
      position: relative;
      z-index: 1;
    }

.bulk-btn {
  min-height: 48px;
  padding: 0 18px;
  border: 1px solid rgba(148, 163, 184, 0.12);
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(18, 31, 50, 0.98) 0%, rgba(9, 18, 32, 1) 100%);
  color: var(--text);
  font-size: 14px;
  font-weight: 800;
  cursor: pointer;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.03),
    0 10px 18px rgba(2, 8, 23, 0.14);
  transition: transform .15s ease, border-color .2s ease;
}

    .bulk-btn:hover {
      border-color: #3a332a;
    }

    .hint {
      color: var(--muted);
      font-size: 13px;
      margin-top: 8px;
      position: relative;
      z-index: 1;
    }

    .big-progress {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 14px;
      min-height: 230px;
      position: relative;
      z-index: 1;
    }

    .big-percent {
      font-size: 58px;
      font-weight: 900;
      line-height: 1;
      color: var(--accent-strong);
      text-shadow: 0 0 24px rgba(201,164,76,0.08);
    }

    .big-sub {
      color: var(--muted);
      font-size: 14px;
    }

    .hero-mini-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

.hero-mini {
  padding: 14px;
  border-radius: 18px;
  border: 1px solid rgba(148, 163, 184, 0.14);
  background: linear-gradient(180deg, rgba(18, 31, 50, 0.96) 0%, rgba(9, 18, 32, 0.98) 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.03),
    0 8px 18px rgba(2, 8, 23, 0.16);
}

    .hero-mini-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 8px;
    }

    .hero-mini-value {
      font-size: 24px;
      font-weight: 900;
      color: var(--text);
    }

.progress-bar,
.small-progress,
.habit-progress-bar {
  width: 100%;
  overflow: hidden;
  border: 1px solid rgba(148, 163, 184, 0.16);
  background: rgba(11, 21, 36, 0.88);
  border-radius: 999px;
}

    .progress-bar { height: 12px; }
    .small-progress { height: 8px; }
    .habit-progress-bar {
  height: 6px;
  margin-top: 6px;
  margin-bottom: 6px;
  box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.28);
}

    .progress-fill,
    .small-fill,
    .habit-progress-fill {
      height: 100%;
      transition: width 0.3s ease;
    }

.progress-fill {
  width: 0%;
  background: linear-gradient(90deg, #0ea5e9 0%, #38bdf8 48%, #7dd3fc 100%);
  box-shadow: 0 0 16px rgba(56, 189, 248, 0.22);
}

.small-fill {
  width: 0%;
  background: linear-gradient(90deg, #0ea5e9 0%, #7dd3fc 100%);
}

.habit-progress-fill {
  width: 0%;
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #0ea5e9 0%, #38bdf8 55%, #7dd3fc 100%);
  box-shadow: 0 0 10px rgba(56, 189, 248, 0.18);
}

/* ===== KPI 카드 고급화 (덮어쓰기) ===== */

.stat-card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(125, 211, 252, 0.16);
  background:
    linear-gradient(180deg, rgba(24, 38, 60, 0.98) 0%, rgba(13, 24, 40, 0.98) 100%);
  box-shadow:
    0 18px 40px rgba(2, 8, 23, 0.34),
    inset 0 1px 0 rgba(255,255,255,0.05),
    0 0 0 1px rgba(125, 211, 252, 0.04);
}

.stat-card::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.10), transparent 32%),
    linear-gradient(180deg, rgba(255,255,255,0.04), transparent 24%);
}

.stat-card:hover {
  transform: translateY(-3px);
  box-shadow:
    0 22px 50px rgba(2, 8, 23, 0.42),
    0 0 0 1px rgba(125, 211, 252, 0.08),
    0 0 24px rgba(56, 189, 248, 0.08);
}

.stat-label {
  color: rgba(154, 166, 191, 0.92);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: -0.01em;
}

.stat-value {
  font-size: 44px;
  font-weight: 900;
  letter-spacing: -0.04em;
  color: #f8fbff;
  text-shadow: 0 2px 18px rgba(0,0,0,0.22);
}

.stat-sub {
  color: rgba(154, 166, 191, 0.72);
  font-size: 12px;
  line-height: 1.45;
}

    .habit-list {
      margin-top: 8px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

.habit-table-section {
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

.habit-table-scroll {
  width: 100%;
  max-height: calc(100vh - 250px); /* 또는 height: 420px 유지 가능 */
  overflow-x: visible;
  overflow-y: auto;
  border: 1px solid rgba(125, 211, 252, 0.12);
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(10, 19, 34, 0.96) 0%, rgba(7, 14, 26, 0.98) 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.03),
    0 10px 24px rgba(2, 8, 23, 0.18);
}

.habit-table {
  width: 100%;
  min-width: 1240px;
  border-collapse: collapse;
  table-layout: fixed;
  background: transparent;
}

.habit-table thead th {
  position: sticky;
  top: 0;
  z-index: 2;

  height: 44px;
  padding: 0;

  background: linear-gradient(180deg, rgba(18, 28, 46, 0.96), rgba(10, 18, 31, 0.96));
  color: #f4e7b2;

  font-size: 13px;
  font-weight: 800;
  text-align: center;
}

.habit-table tbody td {
  padding: 10px 8px;
  font-size: 13px;
  text-align: center;
  vertical-align: middle;
  border-bottom: 1px solid rgba(148, 163, 184, 0.08);
}

.habit-check-cell {
  width: 28px;
  min-width: 28px;
  padding: 6px 3px !important;
}

.habit-progress-cell {
  width: 110px;
  min-width: 110px;
  text-align: center;
  padding: 8px 10px !important;
}

.day-check {
  width: 18px;
  height: 18px;
  accent-color: #38bdf8;
  cursor: pointer;
}

.day-box {
  width: 16px;
  height: 16px;
  margin: 0 auto;
  border-radius: 4px;
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.16);
  cursor: pointer;
  transition: all 0.15s ease;
}

.day-box {
  position: relative;
}

/* 체크 상태 강화 */
.day-box.checked {
  transform: scale(1.08);
  box-shadow:
    0 0 0 1px rgba(56, 189, 248, 0.35),
    0 0 10px rgba(56, 189, 248, 0.35),
    0 0 18px rgba(56, 189, 248, 0.25);
}

/* ripple 효과 */
.day-box::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 4px;
  opacity: 0;
  pointer-events: none;
}

.day-box.checked::after {
  animation: checkRipple 0.4s ease;
}

@keyframes checkRipple {
  0% {
    opacity: 0.6;
    transform: scale(0.8);
    box-shadow: 0 0 0 rgba(56, 189, 248, 0.4);
  }
  70% {
    opacity: 0.3;
    transform: scale(1.2);
    box-shadow: 0 0 12px rgba(56, 189, 248, 0.25);
  }
  100% {
    opacity: 0;
    transform: scale(1.4);
    box-shadow: 0 0 20px rgba(56, 189, 248, 0);
  }
}

.day-box:hover {
  transform: scale(1.08);
  border-color: #38bdf8;
  background: rgba(56,189,248,0.18);
}

.day-box.checked {
  background: #38bdf8;
  border-color: #38bdf8;
  box-shadow: 0 0 8px rgba(56,189,248,0.45);
}

.habit-table tbody td {
  padding: 6px 2px;
  border-bottom: 1px solid rgba(148, 163, 184, 0.08);
  text-align: center;
  font-size: 11px;
}

.habit-table tbody td:first-child {
  width: 180px;
  min-width: 180px;
  text-align: left;
  padding: 8px 10px 8px 12px;
  font-weight: 700;
  vertical-align: middle;
}

.habit-name-cell {
  width: 180px;
  min-width: 180px;
  max-width: 180px;
  overflow: visible;
}

.habit-name-main {
  font-size: 14px;
  line-height: 1.15;
  white-space: normal;
  overflow: visible;
  text-overflow: unset;
  word-break: keep-all;
}

.habit-name-sub {
  margin-top: 2px;
  font-size: 9px;
  color: var(--muted);
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.habit-table tbody tr:hover {
  background: rgba(125, 211, 252, 0.03);
}

.habit-check-cell {
  width: 28px;
  min-width: 28px;
  padding: 6px 3px !important;
}

.habit-table thead .today-col {
  background: linear-gradient(180deg, rgba(56, 189, 248, 0.30), rgba(56, 189, 248, 0.20));
  color: #ffffff;
  box-shadow:
    inset 0 -1px 0 rgba(125, 211, 252, 0.38),
    0 0 0 1px rgba(56, 189, 248, 0.10);
}

.habit-table tbody .today-col {
  position: relative;
  background: rgba(56, 189, 248, 0.12);
}

.habit-table tbody .today-col::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  box-shadow:
    inset 1px 0 0 rgba(125, 211, 252, 0.20),
    inset -1px 0 0 rgba(125, 211, 252, 0.20);
}

.habit-table tbody .today-col .day-box {
  transform: none;
  border-color: rgba(125, 211, 252, 0.30);
  box-shadow: none;
}

.habit-table tbody .today-col .day-box:hover {
  transform: scale(1.08);
  border-color: #7dd3fc;
  background: rgba(56, 189, 248, 0.20);
  box-shadow: 0 0 8px rgba(56, 189, 248, 0.18);
}

.habit-table tbody .today-col .day-box.checked {
  background: #38bdf8;
  border-color: #38bdf8;
  box-shadow: 0 0 8px rgba(56, 189, 248, 0.38);
}

.habit-check-btn {
  width: 22px;
  height: 22px;
  border-radius: 7px;
  border: 1px solid rgba(125, 211, 252, 0.35);
  background: rgba(255, 255, 255, 0.03);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: transparent;
  transition: transform .15s ease, background .2s ease, border-color .2s ease;
}

.habit-check-btn.is-checked {
  background: linear-gradient(180deg, #7dd3fc 0%, #38bdf8 55%, #0ea5e9 100%);
  border-color: rgba(125, 211, 252, 0.5);
  color: #04111d;
  box-shadow: 0 0 12px rgba(56, 189, 248, 0.22);
}

.habit-check-btn:hover {
  transform: scale(1.06);
}

.habit-progress-cell {
  min-width: 110px;
}

.habit-manage-cell {
  width: 240px;
  min-width: 240px;
  text-align: center;
  vertical-align: middle;
  padding: 10px 12px !important;
}

.habit-manage-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex-wrap: nowrap;
}

.table-action-btn,
.table-icon-btn {
  height: 40px;
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 10px;
  background: linear-gradient(180deg, rgba(18, 31, 50, 0.98) 0%, rgba(9, 18, 32, 1) 100%);
  color: var(--text);
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
}

.table-action-btn {
  min-width: 72px;
  height: 40px;
  padding: 0 14px;
  border-radius: 12px;
  font-size: 14px;
}

.table-icon-btn {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  font-size: 16px;
}

.table-action-btn:hover,
.table-icon-btn:hover {
  filter: brightness(1.06);
  background: rgba(255,255,255,0.08);
  border-color: rgba(125, 211, 252, 0.28);
}

.table-action-btn:active,
.table-icon-btn:active {
  transform: scale(0.96);
}

.table-action-btn.danger {
  color: #ffb4aa;
  border-color: rgba(248, 113, 113, 0.24);
  background: linear-gradient(180deg, rgba(80, 24, 24, 0.96) 0%, rgba(52, 14, 14, 1) 100%);
}

.habit-progress-mini {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  overflow: hidden;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(148, 163, 184, 0.10);
  margin-top: 6px;
}

.habit-progress-mini-fill {
  height: 100%;
  width: 0%;
  border-radius: 999px;
  background: linear-gradient(90deg, #0ea5e9 0%, #38bdf8 55%, #7dd3fc 100%);
}

@media (max-width: 700px) {
  .habit-table {
    min-width: 760px;
  }

  .habit-table thead th,
  .habit-table tbody td {
    padding: 10px 8px;
    font-size: 12px;
  }

  .habit-table tbody td:first-child {
    min-width: 180px
  }
}

.habit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  background: linear-gradient(180deg, rgba(18, 31, 50, 0.98) 0%, rgba(9, 18, 32, 1) 100%);
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 20px;
  padding: 14px 16px;
  cursor: grab;
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  will-change: transform;

  /* 👇 이거 추가 */
  position: relative;
}

.habit-row.selected {
  border-color: rgba(56, 189, 248, 0.9) !important;
  box-shadow:
    0 0 0 1px rgba(56, 189, 248, 0.28),
    0 0 24px rgba(56, 189, 248, 0.18),
    0 18px 34px rgba(2, 8, 23, 0.22) !important;
  background:
    linear-gradient(180deg, rgba(20, 38, 64, 0.98) 0%, rgba(11, 21, 36, 1) 100%) !important;
}

.habit-row.selected .habit-name {
  color: #ffffff;
}

.habit-row.drag-over {
  border-color: rgba(125, 211, 252, 0.75) !important;
  background: rgba(125, 211, 252, 0.16) !important;
  box-shadow: 0 0 0 2px rgba(125, 211, 252, 0.28) !important;
  transform: scale(1.01);
}

.habit-row.selected::before {
  content: "";
  position: absolute;
  left: 0;
  top: 12px;
  bottom: 12px;
  width: 3px;
  border-radius: 999px;
  background: linear-gradient(180deg, #7dd3fc 0%, #0ea5e9 100%);
  box-shadow: 0 0 12px rgba(56, 189, 248, 0.30);
}

.selected-habit-panel {
  border: 1px solid rgba(125, 211, 252, 0.18);
  border-radius: 20px;
  background:
    linear-gradient(180deg, rgba(17, 30, 49, 0.96) 0%, rgba(9, 18, 32, 0.98) 100%);
  padding: 15px;
  box-shadow:
    0 14px 30px rgba(2, 8, 23, 0.24),
    0 0 0 1px rgba(125, 211, 252, 0.05);
  margin-bottom: 14px;
  backdrop-filter: blur(10px);
}

/* ===== 차트 카드 고급화 ===== */

.card canvas {
  border-radius: 14px;
  background: rgba(255,255,255,0.02);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.03),
    0 10px 24px rgba(2, 8, 23, 0.22);
  padding: 6px;
}

.card:hover canvas {
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.04),
    0 14px 32px rgba(2, 8, 23, 0.32),
    0 0 20px rgba(56, 189, 248, 0.08);
}

.card::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  border-radius: inherit;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.card:hover::after {
  opacity: 1;
  background:
    radial-gradient(circle at bottom left, rgba(56, 189, 248, 0.08), transparent 40%);
}

.selected-habit-title {
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  margin-bottom: 8px;
}

.selected-habit-name {
  font-size: 19px;
  font-weight: 900;
  line-height: 1.35;
  color: var(--text);
  margin-bottom: 10px;
}

.selected-habit-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 30px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  margin-bottom: 12px;
}

.selected-habit-streak-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
